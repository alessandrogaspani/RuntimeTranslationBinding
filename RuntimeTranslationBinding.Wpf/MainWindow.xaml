<Window x:Class="RuntimeTranslationBinding.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RuntimeTranslationBinding.Wpf"
        xmlns:loc="clr-namespace:RuntimeTranslationBinding.Wpf.Localization"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Resources>
                <Style TargetType="FrameworkElement">
                    <Setter Property="Margin" Value="0,0,0,12" />
                </Style>
            </StackPanel.Resources>
            <TextBlock Text="{loc:Localization Key=selezionaUDM}" FontSize="24"/>
            <Button Content="English" Click="English_Click" />
            <Button Content="Italiano" Click="Italian_Click" />
        </StackPanel>
    </Grid>
</Window>
