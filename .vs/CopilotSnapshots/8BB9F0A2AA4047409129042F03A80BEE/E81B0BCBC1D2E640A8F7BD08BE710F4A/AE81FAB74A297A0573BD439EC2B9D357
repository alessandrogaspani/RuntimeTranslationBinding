namespace RuntimeTranslationBinding.WinUI3
{
    /// <summary>
    /// An empty window that can be used on its own or navigated to within a Frame.
    /// </summary>
    public sealed partial class MainWindow : Window
    {
        public MainWindow()
        {
            InitializeComponent();
            RefreshLocalizedContent();
        }

        private void English_Click(object sender, RoutedEventArgs e)
        {
            LocalizationService.ChangeCulture(LanguageValues.en_US);
            RefreshLocalizedContent();
        }

        private void Italian_Click(object sender, RoutedEventArgs e)
        {
            LocalizationService.ChangeCulture(LanguageValues.it_IT);
            RefreshLocalizedContent();
        }

        private void RefreshLocalizedContent()
        {
            LocalizedTitle.Text = LocalizationService.LocalizeString("selezionaUDM");
        }
    }
}
